{
    "name": "karabinse/contact-form",
    "description": "Basic contact message used for public facing contact forms",
    "keywords": [
        "karabinse",
        "laravel",
        "contact-form"
    ],
    "homepage": "https://github.com/KarabinSE/contact-form",
    "license": "MIT",
    "authors": [
        {
            "name": "Albin N",
            "email": "albin@myrmalm.se",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "*",
        "spatie/laravel-package-tools": "^1.9.2"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "nunomaduro/collision": "^6.0",
        "orchestra/testbench": "^7.0",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "KarabinSE\\ContactForm\\": "src",
            "KarabinSE\\ContactForm\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KarabinSE\\ContactForm\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KarabinSE\\ContactForm\\ContactFormServiceProvider"
            ],
            "aliases": {
                "ContactForm": "KarabinSE\\ContactForm\\Facades\\ContactForm"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
